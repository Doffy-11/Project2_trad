. save `imf_tmp'
file /var/folders/7q/zwm3gpld2llgwyynl4bctfv80000gn/T//St28176.000004 saved
    as .dta format

. restore

. merge m:1 year month using `imf_tmp', keep(match master) nogen

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                             9,072  
    -----------------------------------------

. 
. gen Z_imf = w_trad * imf_shock
(54 missing values generated)

. label var Z_imf "Bartik IV: w_trad x IMF non-fuel AR(1) shock"

