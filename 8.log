. di "Pairwise group-difference t-statistics (two-sided, N(0,1) critical 1.96):
> "
Pairwise group-difference t-statistics (two-sided, N(0,1) critical 1.96):

. di ""


. di "  h     Core-Peri   Core-SOE   Peri-SOE"
  h     Core-Peri   Core-SOE   Peri-SOE

. foreach h in 0 3 6 9 12 {
  2.     local n = `h' + 1
  3. 
.     qui su b_core  if _n == `n'
  4.     local bc = r(mean)
  5.     qui su b_peri  if _n == `n'
  6.     local bp = r(mean)
  7.     qui su b_soe   if _n == `n'
  8.     local bs = r(mean)
  9.     qui su se_core if _n == `n'
 10.     local sc = r(mean)
 11.     qui su se_peri if _n == `n'
 12.     local sp = r(mean)
 13.     qui su se_soe  if _n == `n'
 14.     local ss = r(mean)
 15. 
.     local t_cp = (`bc' - `bp') / sqrt(`sc'^2 + `sp'^2)
 16.     local t_cs = (`bc' - `bs') / sqrt(`sc'^2 + `ss'^2)
 17.     local t_ps = (`bp' - `bs') / sqrt(`sp'^2 + `ss'^2)
 18. 
.     di "  `h'     " %6.2f `t_cp' "     " %6.2f `t_cs' "     " %6.2f `t_ps'
 19. }
  0      -1.05       1.13       1.96
  3      -1.43      -0.58       0.96
  6      -1.30       0.12       1.43
  9      -0.35       0.11       0.44
  12      -0.23       0.13       0.34

